{
  "name": "mud-engineer-pro",
  "version": "1.0.0",
  "description": "Drilling-fluids field calculators, training courses and built-in mud manual — fully offline. Windows / iOS / Android.",
  "author": "Mud Engineer Pro",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "web": "node copy-web.js",
    "start": "node copy-web.js && npx http-server www -p 8080 -c-1 -o",
    "cap:sync": "node copy-web.js && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "win:dev": "node copy-web.js && electron .",
    "win:build": "node copy-web.js && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.mudengineer.pro",
    "productName": "Mud Engineer Pro",
    "directories": { "output": "dist-win" },
    "files": ["electron/**", "www/**"],
    "win": { "target": "nsis", "icon": "build/icon.ico" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/ios": "^6.1.0"
  }
}
